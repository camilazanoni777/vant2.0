<style>
  /* ── VANT CATEGORIES ────────────────────────────────── */

  .vant-categories {
    background:
      radial-gradient(circle at top left, rgba(232, 208, 138, 0.07), transparent 32%),
      radial-gradient(circle at bottom right, rgba(217, 167, 160, 0.07), transparent 34%),
      var(--vant-deep, #101711);
    padding: 80px 5vw;
  }

  .vant-categories__inner {
    max-width: 1440px;
    margin: 0 auto;
  }

  /* ── SECTION HEADER ─────────────────────────────────── */

  .vant-categories__header {
    margin-bottom: 42px;
  }

  .vant-categories__label {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 11.5px;
    letter-spacing: 2.2px;
    text-transform: uppercase;
    color: var(--vant-gold-light, #e8d08a);
    margin-bottom: 1.15rem;
  }

  .vant-categories__label::after {
    content: '';
    display: block;
    width: 60px;
    height: 0.5px;
    background: linear-gradient(to right,
      rgba(201, 168, 76, 0.45),
      transparent
    );
  }

  .vant-categories__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: clamp(36px, 4.5vw, 58px);
    line-height: 1.05;
    color: var(--vant-cream, #f0e8d5);
    margin: 0;
    max-width: 520px;
  }

  /* ── GRID ───────────────────────────────────────────── */

  .vant-categories__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
    align-items: stretch;
  }

  /* 5th card spans 2 cols centered (cols 2–3 of 4) */
  .vant-cat-card--wide {
    grid-column: 2 / span 2;
    aspect-ratio: 2.4 / 1;
    min-height: 260px;
    max-height: 320px;
    height: auto;
  }

  /* ── CARD ───────────────────────────────────────────── */

  .vant-cat-card {
    display: block;
    text-decoration: none;
    position: relative;
    aspect-ratio: 4 / 5;
    min-height: auto;
    border-radius: 28px;
    border: 1px solid rgba(232, 208, 138, 0.20);
    background:
      radial-gradient(circle at 50% 34%, rgba(217, 167, 160, 0.10), transparent 36%),
      linear-gradient(145deg, rgba(33, 53, 40, 0.94), rgba(16, 23, 17, 0.98));
    overflow: hidden;
    cursor: pointer;
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.16);
    transition: transform 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
  }

  .vant-cat-card:hover {
    transform: translateY(-4px);
    border-color: rgba(232, 208, 138, 0.36);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.20);
  }

  /* Background layer — scales on hover */
  .vant-cat-card__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    transition: transform 0.6s ease;
  }

  .vant-cat-card::before {
    content: '';
    position: absolute;
    inset: 1px;
    z-index: 1;
    border-radius: inherit;
    background:
      radial-gradient(circle at 50% 26%, rgba(232, 208, 138, 0.08), transparent 34%),
      radial-gradient(circle at 22% 18%, rgba(217, 167, 160, 0.08), transparent 28%);
    opacity: 0.55;
    pointer-events: none;
  }

  .vant-cat-card:hover .vant-cat-card__bg {
    transform: scale(1.025);
  }

  /* Gradient overlay — bottom fade for text legibility */
  .vant-cat-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(16, 23, 17, 0.88) 0%,
      rgba(16, 23, 17, 0.34) 46%,
      rgba(217, 167, 160, 0.04) 100%
    );
    z-index: 2;
    transition: opacity 0.4s ease;
  }

  .vant-cat-card:hover .vant-cat-card__overlay {
    opacity: 0.72;
  }

  /* SVG icon — decorative, behind text */
  .vant-cat-card__icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 42%;
    max-width: 160px;
    height: auto;
    opacity: 0.20;
    z-index: 3;
    transition: opacity 0.35s ease, transform 0.35s ease;
    pointer-events: none;
  }

  .vant-cat-card__icon svg {
    transform: scale(0.78);
  }

  .vant-cat-card__icon svg [stroke] {
    stroke: var(--vant-gold-light, #e8d08a);
  }

  .vant-cat-card:hover .vant-cat-card__icon {
    opacity: 0.30;
  }

  .vant-cat-card:hover .vant-cat-card__icon svg {
    transform: scale(0.84);
  }

  /* Content — bottom of card */
  .vant-cat-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 22px;
    z-index: 4;
  }

  .vant-cat-card__name {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 23px;
    color: var(--vant-cream, #fbf4e6);
    margin: 0 0 0.35rem 0;
    line-height: 1.1;
  }

  .vant-cat-card__phrase {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 13px;
    line-height: 1.5;
    color: var(--vant-text-muted, #c2b69c);
    margin: 0 0 0.72rem 0;
  }

  .vant-cat-card__count {
    display: block;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--vant-gold-light, #e8d08a);
    margin-bottom: 0.72rem;
  }

  .vant-cat-card__cta {
    display: inline-block;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--vant-champagne, #d8c89f);
    transition: color 0.3s ease, letter-spacing 0.3s ease;
  }

  .vant-cat-card:hover .vant-cat-card__cta {
    color: var(--vant-gold-light, #e8d08a);
    letter-spacing: 2px;
  }

  /* ── RESPONSIVE ─────────────────────────────────────── */

  /* Wide banner treatment for the 5th category card (Conjuntos). */
  .vant-cat-card--wide .vant-cat-card__content {
    padding: 28px 34px;
    max-width: 55%;
  }

  .vant-cat-card--wide .vant-cat-card__icon {
    width: 28%;
    max-width: 180px;
    right: 10%;
    top: 50%;
    left: auto;
    transform: translateY(-50%) scale(0.85);
    opacity: 0.22;
  }

  .vant-cat-card--wide:hover .vant-cat-card__icon {
    opacity: 0.32;
    transform: translateY(-50%) scale(0.92);
  }

  .vant-cat-card--wide .vant-cat-card__icon svg,
  .vant-cat-card--wide:hover .vant-cat-card__icon svg {
    transform: none;
  }

  .vant-cat-card--wide .vant-cat-card__name {
    font-size: 28px;
  }

  .vant-cat-card--wide .vant-cat-card__phrase {
    font-size: 14px;
  }

  .vant-cat-card--wide .vant-cat-card__count {
    font-size: 11px;
  }

  @media screen and (max-width: 989px) {
    .vant-categories {
      padding: 72px 3vw;
    }

    .vant-categories__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }

    .vant-cat-card--wide {
      grid-column: 1 / -1;
      aspect-ratio: 2 / 1;
      min-height: 230px;
      max-height: 280px;
    }

    .vant-categories__header {
      margin-bottom: 36px;
    }
  }

  @media screen and (max-width: 768px) {
    .vant-categories {
      padding: 64px 22px;
    }

    .vant-categories__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .vant-cat-card {
      aspect-ratio: 1 / 1.18;
      border-radius: 22px;
    }

    .vant-cat-card--wide {
      grid-column: 1 / -1;
      aspect-ratio: 1.7 / 1;
      min-height: 210px;
      max-height: 250px;
    }

    .vant-cat-card--wide .vant-cat-card__content {
      max-width: 68%;
      padding: 22px;
    }

    .vant-cat-card--wide .vant-cat-card__icon {
      width: 34%;
      right: 6%;
    }

    .vant-cat-card--wide .vant-cat-card__name {
      font-size: 24px;
    }

    .vant-cat-card__content {
      padding: 16px;
    }

    .vant-cat-card__name {
      font-size: 20px;
    }

    .vant-cat-card__phrase {
      font-size: 12px;
    }

    .vant-cat-card__icon {
      width: 44%;
      max-width: 110px;
    }

    .vant-categories__title {
      font-size: 1.75rem;
    }
  }

  @media screen and (max-width: 480px) {
    .vant-categories__grid {
      grid-template-columns: 1fr;
    }

    .vant-cat-card {
      aspect-ratio: 1.15 / 1;
    }

    .vant-cat-card--wide {
      aspect-ratio: 1.25 / 1;
      min-height: 210px;
      max-height: none;
    }

    .vant-cat-card--wide .vant-cat-card__content {
      max-width: 100%;
    }

    .vant-cat-card--wide .vant-cat-card__icon {
      width: 42%;
      right: 8%;
      opacity: 0.16;
    }
  }
</style>

{%- comment -%}
  Background gradients per icon type
  Assigned inline per card via Liquid case/when
{%- endcomment -%}

<section class="vant-categories" aria-labelledby="vant-cat-title">
  <div class="vant-categories__inner">

    {%- comment -%} Section header {%- endcomment -%}
    <header class="vant-categories__header">
      <p class="vant-categories__label">{{ section.settings.label }}</p>
      <h2 class="vant-categories__title" id="vant-cat-title">{{ section.settings.title }}</h2>
    </header>

    {%- comment -%} Category grid {%- endcomment -%}
    <div class="vant-categories__grid">

      {%- for block in section.blocks -%}
        {%- case block.settings.icon -%}
          {%- when 'ring' -%}    {%- assign card_bg = 'linear-gradient(145deg, rgba(42, 62, 48, 0.96), rgba(18, 27, 20, 0.98))' -%}
          {%- when 'pendant' -%} {%- assign card_bg = 'linear-gradient(145deg, rgba(45, 66, 50, 0.96), rgba(20, 29, 22, 0.98))' -%}
          {%- when 'drop' -%}    {%- assign card_bg = 'linear-gradient(145deg, rgba(38, 58, 43, 0.96), rgba(18, 26, 19, 0.98))' -%}
          {%- when 'oval' -%}    {%- assign card_bg = 'linear-gradient(145deg, rgba(44, 64, 49, 0.96), rgba(20, 29, 22, 0.98))' -%}
          {%- when 'cluster' -%} {%- assign card_bg = 'linear-gradient(145deg, rgba(48, 70, 52, 0.96), rgba(20, 28, 21, 0.98))' -%}
          {%- else -%}           {%- assign card_bg = 'linear-gradient(145deg, rgba(42, 62, 48, 0.96), rgba(18, 27, 20, 0.98))' -%}
        {%- endcase -%}

        {%- assign is_wide = false -%}
        {%- if forloop.index == 5 and section.blocks.size >= 5 -%}
          {%- assign is_wide = true -%}
        {%- endif -%}

        <a
          href="{{ block.settings.link | default: '/collections/all' }}"
          class="vant-cat-card{% if is_wide %} vant-cat-card--wide{% endif %}"
          aria-label="{{ block.settings.name }}"
          {{ block.shopify_attributes }}
        >
          {%- comment -%} Background {%- endcomment -%}
          <div class="vant-cat-card__bg" style="background: {{ card_bg }};"></div>

          {%- comment -%} Overlay {%- endcomment -%}
          <div class="vant-cat-card__overlay" aria-hidden="true"></div>

          {%- comment -%} Decorative SVG icon {%- endcomment -%}
          <div class="vant-cat-card__icon" aria-hidden="true">
            {%- case block.settings.icon -%}

              {%- when 'ring' -%}
              <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="60" cy="60" r="42" stroke="#c9a84c" stroke-width="1"/>
                <circle cx="60" cy="60" r="28" stroke="#c9a84c" stroke-width="0.5" stroke-dasharray="3.5 5"/>
                <circle cx="60" cy="18" r="4" stroke="#c9a84c" stroke-width="0.8" fill="none"/>
              </svg>

              {%- when 'pendant' -%}
              <svg viewBox="0 0 100 150" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="50" y1="5" x2="50" y2="32" stroke="#c9a84c" stroke-width="1" stroke-linecap="round"/>
                <circle cx="50" cy="24" r="9" stroke="#c9a84c" stroke-width="1"/>
                <path d="M50 44 C27 44, 14 66, 14 84 C14 110, 30 142, 50 142 C70 142, 86 110, 86 84 C86 66, 73 44, 50 44 Z" stroke="#c9a84c" stroke-width="1"/>
                <circle cx="50" cy="95" r="8" stroke="#c9a84c" stroke-width="0.5" stroke-dasharray="2 3"/>
              </svg>

              {%- when 'drop' -%}
              <svg viewBox="0 0 70 140" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="35" y1="5" x2="35" y2="28" stroke="#c9a84c" stroke-width="1" stroke-linecap="round"/>
                <circle cx="35" cy="21" r="8" stroke="#c9a84c" stroke-width="1"/>
                <path d="M35 40 C18 48, 10 68, 10 82 C10 108, 21 132, 35 132 C49 132, 60 108, 60 82 C60 68, 52 48, 35 40 Z" stroke="#c9a84c" stroke-width="1"/>
                <ellipse cx="35" cy="100" rx="10" ry="14" stroke="#c9a84c" stroke-width="0.5" stroke-dasharray="2 3"/>
              </svg>

              {%- when 'oval' -%}
              <svg viewBox="0 0 160 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="80" cy="50" rx="70" ry="38" stroke="#c9a84c" stroke-width="1"/>
                <ellipse cx="80" cy="50" rx="50" ry="22" stroke="#c9a84c" stroke-width="0.5" stroke-dasharray="4 5"/>
                <circle cx="10" cy="50" r="4" fill="#c9a84c" opacity="0.5"/>
                <circle cx="150" cy="50" r="4" fill="#c9a84c" opacity="0.5"/>
              </svg>

              {%- when 'cluster' -%}
              <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="60" cy="60" r="18" stroke="#c9a84c" stroke-width="1"/>
                <circle cx="26" cy="36" r="11" stroke="#c9a84c" stroke-width="0.8"/>
                <circle cx="94" cy="36" r="11" stroke="#c9a84c" stroke-width="0.8"/>
                <circle cx="26" cy="84" r="11" stroke="#c9a84c" stroke-width="0.8"/>
                <circle cx="94" cy="84" r="11" stroke="#c9a84c" stroke-width="0.8"/>
                <line x1="37" y1="43" x2="47" y2="51" stroke="#c9a84c" stroke-width="0.5"/>
                <line x1="83" y1="43" x2="73" y2="51" stroke="#c9a84c" stroke-width="0.5"/>
                <line x1="37" y1="77" x2="47" y2="69" stroke="#c9a84c" stroke-width="0.5"/>
                <line x1="83" y1="77" x2="73" y2="69" stroke="#c9a84c" stroke-width="0.5"/>
              </svg>

              {%- else -%}
              <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="60" cy="60" r="42" stroke="#c9a84c" stroke-width="1"/>
              </svg>

            {%- endcase -%}
          </div>

          {%- comment -%} Text content {%- endcomment -%}
          <div class="vant-cat-card__content">
            <h3 class="vant-cat-card__name">{{ block.settings.name }}</h3>
            <p class="vant-cat-card__phrase">{{ block.settings.phrase }}</p>
            <span class="vant-cat-card__count">{{ block.settings.count }}</span>
            <span class="vant-cat-card__cta">Ver coleção →</span>
          </div>

        </a>
      {%- endfor -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "VANT Categorias",
  "class": "vant-categories-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label da seção",
      "default": "COLEÇÕES"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título da seção",
      "default": "Cada peça conta uma história"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoria",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Nome da categoria",
          "default": "Categoria"
        },
        {
          "type": "text",
          "id": "phrase",
          "label": "Frase",
          "default": "Uma frase elegante"
        },
        {
          "type": "text",
          "id": "count",
          "label": "Contagem de peças",
          "default": "12 peças"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link da coleção"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Ícone decorativo",
          "options": [
            { "value": "ring",    "label": "Anel" },
            { "value": "pendant", "label": "Pingente / Colar" },
            { "value": "drop",    "label": "Gota / Brinco" },
            { "value": "oval",    "label": "Oval / Pulseira" },
            { "value": "cluster", "label": "Conjunto / Cluster" }
          ],
          "default": "ring"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VANT Categorias",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "name": "Anéis",
            "phrase": "Cada dedo conta uma história",
            "count": "12 peças",
            "link": "/collections/aneis",
            "icon": "ring"
          }
        },
        {
          "type": "category",
          "settings": {
            "name": "Colares",
            "phrase": "Do pescoço ao coração",
            "count": "18 peças",
            "link": "/collections/colares",
            "icon": "pendant"
          }
        },
        {
          "type": "category",
          "settings": {
            "name": "Brincos",
            "phrase": "O detalhe que transforma",
            "count": "24 peças",
            "link": "/collections/brincos",
            "icon": "drop"
          }
        },
        {
          "type": "category",
          "settings": {
            "name": "Pulseiras",
            "phrase": "Gestos que brilham",
            "count": "15 peças",
            "link": "/collections/pulseiras",
            "icon": "oval"
          }
        },
        {
          "type": "category",
          "settings": {
            "name": "Conjuntos",
            "phrase": "O look completo",
            "count": "8 peças",
            "link": "/collections/conjuntos",
            "icon": "cluster"
          }
        }
      ]
    }
  ]
}
{% endschema %}
