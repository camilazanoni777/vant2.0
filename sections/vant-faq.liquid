<style>
  /* ── VANT FAQ ───────────────────────────────────────── */

  .vant-faq {
    background: linear-gradient(180deg,
      var(--vant-deep,   #0a110d) 0%,
      var(--vant-forest, #0f1f15) 50%,
      var(--vant-deep,   #0a110d) 100%
    );
    padding: 100px 3rem 120px;
  }

  .vant-faq__inner {
    max-width: 820px;
    margin: 0 auto;
  }

  /* ── SECTION HEADER ─────────────────────────────────── */

  .vant-faq__header {
    margin-bottom: 60px;
  }

  .vant-faq__label {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 0.6rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--vant-gold, #c9a84c);
    margin-bottom: 1.2rem;
  }

  .vant-faq__label::after {
    content: '';
    display: block;
    width: 60px;
    height: 0.5px;
    background: linear-gradient(to right, rgba(201, 168, 76, 0.45), transparent);
  }

  .vant-faq__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: clamp(1.9rem, 3.5vw, 3rem);
    line-height: 1.2;
    color: var(--vant-cream, #f0e8d5);
    margin: 0;
  }

  /* ── ACCORDION LIST ─────────────────────────────────── */

  .vant-faq__list {
    border-top: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
  }

  /* ── SINGLE ITEM ────────────────────────────────────── */

  .vant-faq-item {
    border-bottom: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
  }

  /* ── QUESTION BUTTON ────────────────────────────────── */

  .vant-faq-btn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
    background: transparent;
    border: none;
    padding: 1.4rem 0;
    cursor: pointer;
    text-align: left;
    color: var(--vant-cream, #f0e8d5);
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 0.88rem;
    letter-spacing: 0.3px;
    line-height: 1.5;
    transition: color 0.3s ease;
  }

  .vant-faq-btn:hover {
    color: var(--vant-gold-light, #e8d08a);
  }

  .vant-faq-item.open .vant-faq-btn {
    color: var(--vant-gold, #c9a84c);
  }

  /* ── ICON ───────────────────────────────────────────── */

  .vant-faq-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: var(--vant-gold, #c9a84c);
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1;
    transform-origin: center;
    transition: transform 0.4s ease, color 0.3s ease;
    user-select: none;
  }

  .vant-faq-item.open .vant-faq-icon {
    transform: rotate(45deg);
  }

  /* ── ANSWER ─────────────────────────────────────────── */

  .vant-faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .vant-faq-answer-inner {
    padding-bottom: 1.5rem;
  }

  .vant-faq-answer-inner p {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--vant-text-muted, #8fa88a);
    margin: 0;
  }

  /* ── RESPONSIVE ─────────────────────────────────────── */

  @media screen and (max-width: 989px) {
    .vant-faq {
      padding: 72px 2rem 80px;
    }

    .vant-faq__header {
      margin-bottom: 48px;
    }
  }

  @media screen and (max-width: 600px) {
    .vant-faq {
      padding: 60px 1.4rem 68px;
    }

    .vant-faq__title {
      font-size: 1.75rem;
    }

    .vant-faq-btn {
      font-size: 0.83rem;
      padding: 1.2rem 0;
    }
  }
</style>

<section class="vant-faq" aria-labelledby="vant-faq-title">
  <div class="vant-faq__inner">

    {%- comment -%} Section header {%- endcomment -%}
    <header class="vant-faq__header">
      <p class="vant-faq__label">{{ section.settings.label }}</p>
      <h2 class="vant-faq__title" id="vant-faq-title">{{ section.settings.title }}</h2>
    </header>

    {%- comment -%} Accordion {%- endcomment -%}
    <div class="vant-faq__list" id="vant-faq-list-{{ section.id }}">

      {%- for block in section.blocks -%}
        <div class="vant-faq-item" {{ block.shopify_attributes }}>

          <button
            class="vant-faq-btn"
            aria-expanded="false"
            aria-controls="vant-faq-answer-{{ section.id }}-{{ forloop.index }}"
          >
            <span>{{ block.settings.question }}</span>
            <span class="vant-faq-icon" aria-hidden="true">+</span>
          </button>

          <div
            class="vant-faq-answer"
            id="vant-faq-answer-{{ section.id }}-{{ forloop.index }}"
            role="region"
          >
            <div class="vant-faq-answer-inner">
              <p>{{ block.settings.answer }}</p>
            </div>
          </div>

        </div>
      {%- endfor -%}

    </div>
  </div>
</section>

<script>
(function () {
  'use strict';

  var list = document.getElementById('vant-faq-list-{{ section.id }}');
  if (!list) return;

  var items = list.querySelectorAll('.vant-faq-item');

  function openItem(item) {
    var answer = item.querySelector('.vant-faq-answer');
    var btn    = item.querySelector('.vant-faq-btn');
    item.classList.add('open');
    btn.setAttribute('aria-expanded', 'true');
    answer.style.maxHeight = answer.scrollHeight + 'px';
  }

  function closeItem(item) {
    var answer = item.querySelector('.vant-faq-answer');
    var btn    = item.querySelector('.vant-faq-btn');
    item.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
    answer.style.maxHeight = '0px';
  }

  items.forEach(function (item) {
    var btn = item.querySelector('.vant-faq-btn');
    btn.addEventListener('click', function () {
      var isOpen = item.classList.contains('open');

      /* Close all — one-at-a-time behaviour */
      items.forEach(function (i) { closeItem(i); });

      /* Re-open if it was closed before the click */
      if (!isOpen) { openItem(item); }
    });
  });

})();
</script>

{% schema %}
{
  "name": "VANT FAQ",
  "class": "vant-faq-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label da seção",
      "default": "PERGUNTAS FREQUENTES"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título da seção",
      "default": "Tudo que você precisa saber"
    }
  ],
  "blocks": [
    {
      "type": "faq-item",
      "name": "Pergunta e Resposta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pergunta",
          "default": "Qual é a pergunta?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Resposta",
          "default": "Esta é a resposta."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VANT FAQ",
      "blocks": [
        {
          "type": "faq-item",
          "settings": {
            "question": "O que são semijoias?",
            "answer": "Semijoias são joias feitas com metais de alta qualidade revestidos com banho de ouro 18k ou ródio. Possuem acabamento premium e durabilidade superior às bijuterias comuns, sem o custo das joias em ouro maciço."
          }
        },
        {
          "type": "faq-item",
          "settings": {
            "question": "Quanto tempo dura o banho dourado?",
            "answer": "Com os cuidados adequados, o banho de ouro 18k da VANT dura entre 1 e 3 anos. Evite contato com água, perfumes e produtos químicos para maximizar a durabilidade."
          }
        },
        {
          "type": "faq-item",
          "settings": {
            "question": "As peças causam alergia?",
            "answer": "Não. Todas as peças VANT são hipoalergênicas, livres de níquel e produzidas com materiais certificados, seguros para pele sensível."
          }
        },
        {
          "type": "faq-item",
          "settings": {
            "question": "Qual o prazo de entrega?",
            "answer": "Capitais: 3 a 5 dias úteis. Demais regiões: 5 a 10 dias úteis. Você recebe o código de rastreio por e-mail após confirmação do pagamento."
          }
        },
        {
          "type": "faq-item",
          "settings": {
            "question": "Vocês oferecem frete grátis?",
            "answer": "Sim! Pedidos acima de R$199 têm frete grátis para todo o Brasil. Abaixo desse valor, o frete é calculado pelo CEP no checkout."
          }
        },
        {
          "type": "faq-item",
          "settings": {
            "question": "Posso parcelar minha compra?",
            "answer": "Sim. Aceitamos parcelamento em até 12x no cartão de crédito. No Pix você ganha 5% de desconto. Também aceitamos boleto bancário."
          }
        },
        {
          "type": "faq-item",
          "settings": {
            "question": "Como funciona a troca ou devolução?",
            "answer": "Você tem até 7 dias após o recebimento para solicitar troca ou devolução, conforme o Código de Defesa do Consumidor. Contato: contato@vant.com.br"
          }
        },
        {
          "type": "faq-item",
          "settings": {
            "question": "As peças vêm embaladas para presente?",
            "answer": "Sim! Todas as peças VANT são entregues em embalagem premium exclusiva com envelope de veludo e cartão de autenticidade, sem custo adicional."
          }
        }
      ]
    }
  ]
}
{% endschema %}
