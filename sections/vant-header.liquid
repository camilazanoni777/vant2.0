<style>
  :root {
    --vant-deep:       #0a110d;
    --vant-forest:     #101b14;
    --vant-moss:       #1a3022;
    --vant-leaf:       #2a4f35;
    --vant-gold:       #c9a84c;
    --vant-gold-light: #e8d08a;
    --vant-cream:      #f6eddc;
    --vant-champagne:  #ead9bd;
    --vant-rose:       #d9a7a0;
    --vant-rose-soft:  #f1d8d2;
    --vant-nude:       #c8a889;
    --vant-text:       #e8dfc8;
    --vant-text-muted: #b8a98f;
    --vant-border:     rgba(201, 168, 76, 0.2);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    background-color: var(--vant-deep) !important;
    font-family: 'Jost', sans-serif;
    color: var(--vant-text);
    margin: 0;
    padding: 0;
  }

  /* ── HEADER ────────────────────────────────────────── */

  .vant-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 80px;
    z-index: 9999;
    background: rgba(10, 17, 13, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 0.5px solid var(--vant-border);
    transition: background 0.4s ease, box-shadow 0.4s ease;
    display: flex;
    align-items: center;
  }

  .vant-header.scrolled {
    background: rgba(10, 17, 13, 0.98);
    box-shadow:
      0 1px 40px rgba(0, 0, 0, 0.6),
      0 0 0 0.5px rgba(201, 168, 76, 0.12);
  }

  .vant-header__inner {
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
    padding: 0 3rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }

  /* ── LOGO ───────────────────────────────────────────── */

  .vant-header__logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vant-header__logo-text {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 1.6rem;
    color: var(--vant-gold);
    letter-spacing: 6px;
    text-transform: uppercase;
    line-height: 1;
    transition: color 0.3s ease, letter-spacing 0.3s ease;
    text-decoration: none;
  }

  .vant-header__logo-text:hover {
    color: var(--vant-champagne, #ead9bd);
    letter-spacing: 8px;
  }

  /* ── NAV ────────────────────────────────────────────── */

  .vant-header__nav {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    justify-content: flex-start;
  }

  .vant-header__nav-item {
    display: flex;
  }

  .vant-header__nav-link {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--vant-champagne, #ead9bd);
    text-decoration: none;
    padding: 0.55rem 1rem;
    transition: color 0.3s ease;
    position: relative;
    white-space: nowrap;
  }

  .vant-header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0.5px;
    background: var(--vant-gold);
    transition: width 0.35s ease;
  }

  .vant-header__nav-link:hover {
    color: var(--vant-gold-light, #e8d08a);
  }

  .vant-header__nav-link:hover::after {
    width: 55%;
  }

  /* ── ICONS ──────────────────────────────────────────── */

  .vant-header__icons {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    justify-content: flex-end;
  }

  .vant-header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--vant-text-muted);
    text-decoration: none;
    transition: color 0.3s ease;
    position: relative;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .vant-header__icon:hover {
    color: var(--vant-champagne, #ead9bd);
  }

  .vant-header__icon svg {
    width: 17px;
    height: 17px;
  }

  /* Cart badge — always visible */
  .vant-cart-badge {
    position: absolute;
    top: 5px;
    right: 5px;
    min-width: 15px;
    height: 15px;
    background: var(--vant-gold);
    color: var(--vant-deep);
    border-radius: 50%;
    font-family: 'Jost', sans-serif;
    font-size: 8px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 2px;
    line-height: 1;
    pointer-events: none;
  }

  /* ── HAMBURGER ──────────────────────────────────────── */

  .vant-header__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 8px 6px;
    align-items: flex-start;
  }

  .vant-header__hamburger span {
    display: block;
    width: 22px;
    height: 0.5px;
    background: var(--vant-text-muted);
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .vant-header__hamburger.active span:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
    background: var(--vant-gold);
  }

  .vant-header__hamburger.active span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .vant-header__hamburger.active span:nth-child(3) {
    transform: translateY(-5.5px) rotate(-45deg);
    background: var(--vant-gold);
  }

  /* ── MOBILE NAV ─────────────────────────────────────── */

  .vant-mobile-nav {
    position: fixed;
    top: 80px;
    left: 0;
    width: 100%;
    background: rgba(10, 17, 13, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 0.5px solid var(--vant-border);
    padding: 1.5rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    list-style: none;
    margin: 0;
    transform: translateY(-10px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.35s ease, opacity 0.35s ease;
    z-index: 9998;
  }

  .vant-mobile-nav.active {
    transform: translateY(0);
    opacity: 1;
    pointer-events: all;
  }

  .vant-mobile-nav li {
    border-bottom: 0.5px solid rgba(201, 168, 76, 0.08);
  }

  .vant-mobile-nav li:last-child {
    border-bottom: none;
  }

  .vant-mobile-nav a {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 0.7rem;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--vant-champagne, #ead9bd);
    text-decoration: none;
    padding: 1rem 0;
    display: block;
    transition: color 0.3s ease, padding-left 0.3s ease;
  }

  .vant-mobile-nav a:hover {
    color: var(--vant-gold-light, #e8d08a);
    padding-left: 0.5rem;
  }

  /* ── RESPONSIVE ─────────────────────────────────────── */

  @media screen and (max-width: 989px) {
    .vant-header__inner {
      grid-template-columns: auto 1fr auto;
      padding: 0 1.5rem;
      gap: 0;
    }

    .vant-header__nav {
      display: none;
    }

    .vant-header__logo {
      justify-content: center;
    }

    .vant-header__hamburger {
      display: flex;
    }
  }

  @media screen and (max-width: 480px) {
    .vant-header__inner {
      padding: 0 1.2rem;
    }

    .vant-header__logo-text {
      letter-spacing: 6px;
      font-size: 1.4rem;
    }
  }

  /* Override Dawn header section wrapper stickiness */
  .section-header {
    position: static !important;
    margin-bottom: 0 !important;
  }
</style>

<header class="vant-header" id="vant-header" role="banner">
  <div class="vant-header__inner">

    {%- comment -%} Col 1 — Hamburger (mobile) + Nav (desktop) {%- endcomment -%}
    <div style="display:flex;align-items:center;">
      <button
        class="vant-header__hamburger"
        id="vant-hamburger"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="vant-mobile-nav"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav aria-label="Navegação principal">
        <ul class="vant-header__nav">
          <li class="vant-header__nav-item">
            <a href="/collections/all" class="vant-header__nav-link">Coleções</a>
          </li>
          <li class="vant-header__nav-item">
            <a href="/collections" class="vant-header__nav-link">Categorias</a>
          </li>
          <li class="vant-header__nav-item">
            <a href="/collections/lancamento" class="vant-header__nav-link">Lançamento</a>
          </li>
          <li class="vant-header__nav-item">
            <a href="/pages/faq" class="vant-header__nav-link">FAQ</a>
          </li>
          <li class="vant-header__nav-item">
            <a href="/pages/contact" class="vant-header__nav-link">Contato</a>
          </li>
        </ul>
      </nav>
    </div>

    {%- comment -%} Col 2 — Logo (center) {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="vant-header__logo" aria-label="{{ shop.name }}">
      <span class="vant-header__logo-text">VANT</span>
    </a>

    {%- comment -%} Col 3 — Icons (right) {%- endcomment -%}
    <div class="vant-header__icons">

      <a href="{{ routes.search_url }}" class="vant-header__icon" aria-label="Buscar">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25">
          <circle cx="11" cy="11" r="7"/>
          <line x1="16.5" y1="16.5" x2="22" y2="22" stroke-linecap="round"/>
        </svg>
      </a>

      <a href="/pages/wishlist" class="vant-header__icon" aria-label="Favoritos">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </a>

      <a
        href="{{ routes.cart_url }}"
        class="vant-header__icon"
        id="cart-icon-bubble"
        aria-label="Carrinho — {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'itens' }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="vant-cart-badge cart-count-bubble" aria-hidden="true">{{ cart.item_count }}</span>
      </a>

    </div>
  </div>
</header>

{%- comment -%} Mobile nav overlay {%- endcomment -%}
<ul class="vant-mobile-nav" id="vant-mobile-nav" role="list" aria-label="Menu mobile">
  <li><a href="/collections/all">Coleções</a></li>
  <li><a href="/collections">Categorias</a></li>
  <li><a href="/collections/lancamento">Lançamento</a></li>
  <li><a href="/pages/faq">FAQ</a></li>
  <li><a href="/pages/contact">Contato</a></li>
</ul>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification', color_scheme: 'scheme-1' -%}
{%- endif -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

<script>
  (function () {
    const header    = document.getElementById('vant-header');
    const hamburger = document.getElementById('vant-hamburger');
    const mobileNav = document.getElementById('vant-mobile-nav');

    // Scroll → intensify header
    window.addEventListener('scroll', function () {
      header.classList.toggle('scrolled', window.pageYOffset > 80);
    }, { passive: true });

    // Hamburger toggle
    hamburger.addEventListener('click', function () {
      const isOpen = mobileNav.classList.contains('active');
      mobileNav.classList.toggle('active', !isOpen);
      hamburger.classList.toggle('active', !isOpen);
      hamburger.setAttribute('aria-expanded', String(!isOpen));
      hamburger.setAttribute('aria-label', isOpen ? 'Abrir menu' : 'Fechar menu');
    });

    // Close on desktop resize
    window.addEventListener('resize', function () {
      if (window.innerWidth > 989) {
        mobileNav.classList.remove('active');
        hamburger.classList.remove('active');
        hamburger.setAttribute('aria-expanded', 'false');
        hamburger.setAttribute('aria-label', 'Abrir menu');
      }
    });

    // Close when clicking outside
    document.addEventListener('click', function (e) {
      if (!header.contains(e.target) && !mobileNav.contains(e.target)) {
        mobileNav.classList.remove('active');
        hamburger.classList.remove('active');
        hamburger.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "VANT Header",
  "class": "section-header",
  "settings": []
}
{% endschema %}
