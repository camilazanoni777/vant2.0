<style>
  /* ── VANT PRODUCTS ──────────────────────────────────── */

  .vant-products {
    background:
      radial-gradient(ellipse at 50% 100%, rgba(217, 167, 160, 0.06) 0%, transparent 54%),
      radial-gradient(circle at top right, rgba(232, 208, 138, 0.04), transparent 30%),
      linear-gradient(180deg,
        var(--vant-deep,   #101711) 0%,
        var(--vant-forest, #162319) 48%,
        var(--vant-deep,   #101711) 100%
      );
    padding: 88px 5vw 96px;
  }

  .vant-products__inner {
    max-width: 1440px;
    margin: 0 auto;
  }

  /* ── SECTION HEADER ─────────────────────────────────── */

  .vant-products__header {
    margin-bottom: 34px;
  }

  .vant-products__label {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 11.5px;
    letter-spacing: 2.2px;
    text-transform: uppercase;
    color: var(--vant-gold-light, #e8d08a);
    margin-bottom: 1.2rem;
  }

  .vant-products__label::after {
    content: '';
    display: block;
    width: 60px;
    height: 0.5px;
    background: linear-gradient(to right, rgba(201, 168, 76, 0.45), transparent);
  }

  .vant-products__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: clamp(36px, 4.5vw, 58px);
    line-height: 1.05;
    color: var(--vant-cream, #f0e8d5);
    margin: 0;
    max-width: 480px;
  }

  /* ── FILTER TABS ────────────────────────────────────── */

  .vant-products__filters {
    display: flex;
    align-items: flex-end;
    gap: 24px;
    margin-bottom: 34px;
    border-bottom: 1px solid rgba(232, 208, 138, 0.18);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .vant-products__filters::-webkit-scrollbar { display: none; }

  .vant-filter-btn {
    background: transparent;
    border: none;
    border-bottom: 1px solid transparent;
    color: var(--vant-text-muted, #8fa88a);
    text-transform: uppercase;
    font-size: 11.5px;
    letter-spacing: 1.8px;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    cursor: pointer;
    padding: 0 0 12px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.3s ease, border-color 0.3s ease;
    margin-bottom: -0.5px;
  }

  .vant-filter-btn.active {
    color: var(--vant-gold-light, #e8d08a);
    border-bottom-color: var(--vant-gold-light, #e8d08a);
  }

  .vant-filter-btn:hover:not(.active) {
    color: var(--vant-champagne, #d8c89f);
  }

  .vant-products__drag-hint {
    display: flex;
    justify-content: flex-end;
    margin: -22px 4px 18px;
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: lowercase;
    color: var(--vant-text-muted, #8fa88a);
    opacity: 0.75;
  }

  /* ── CAROUSEL ───────────────────────────────────────── */

  .vant-products-carousel-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .vant-products-carousel {
    display: flex;
    gap: 22px;
    overflow-x: auto;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 8px 4px 26px;
    scroll-padding-left: 4px;
    cursor: grab;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    user-select: none;
  }

  .vant-products-carousel::-webkit-scrollbar {
    display: none;
  }

  .vant-products-carousel.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
  }

  .vant-carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 999px;
    background: rgba(16, 23, 17, 0.78);
    border: 1px solid rgba(232, 208, 138, 0.24);
    color: var(--vant-champagne, #d8c89f);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
    backdrop-filter: blur(10px);
    transition: background 0.28s ease, color 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
  }

  .vant-carousel-arrow:hover {
    background: var(--vant-gold-light, #e8d08a);
    color: var(--vant-deep, #101711);
    border-color: rgba(232, 208, 138, 0.5);
    box-shadow: 0 0 24px rgba(232, 208, 138, 0.16);
  }

  .vant-carousel-arrow svg {
    width: 18px;
    height: 18px;
  }

  .vant-carousel-prev { left: 4px; }
  .vant-carousel-next { right: 4px; }

  /* ── CARD ───────────────────────────────────────────── */

  .vant-product-card {
    flex: 0 0 calc((100% - 84px) / 4);
    max-width: 360px;
    scroll-snap-align: start;
    background:
      radial-gradient(circle at top center, rgba(217, 167, 160, 0.08), transparent 38%),
      linear-gradient(180deg, rgba(33, 53, 40, 0.96), rgba(16, 23, 17, 0.98));
    border: 1px solid rgba(232, 208, 138, 0.18);
    border-radius: 26px;
    overflow: hidden;
    position: relative;
    cursor: pointer;
    /* Render visible by default; JS can still add .is-visible for enhancement. */
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 0.45s ease,
      transform 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease;
    box-shadow: 0 16px 44px rgba(0, 0, 0, 0.14);
  }

  .vant-product-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .vant-product-card.is-hidden {
    display: none;
  }

  .vant-product-card.is-visible:hover {
    border-color: rgba(232, 208, 138, 0.36);
    transform: translateY(-4px);
    box-shadow: 0 22px 60px rgba(0, 0, 0, 0.20);
  }

  /* ── IMAGE AREA ─────────────────────────────────────── */

  .vant-product-image {
    aspect-ratio: 1 / 0.88;
    min-height: 260px;
    background:
      radial-gradient(circle at center, rgba(232, 208, 138, 0.08), transparent 40%),
      radial-gradient(circle at 50% 35%, rgba(217, 167, 160, 0.08), transparent 34%),
      var(--vant-moss, #1a3022);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* ── BADGE ──────────────────────────────────────────── */

  .vant-badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 3;
    font-family: 'Jost', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    border-radius: 999px;
    padding: 5px 11px;
    line-height: 1;
    pointer-events: none;
  }

  .vant-badge--novo {
    background: var(--vant-gold-light, #e8d08a);
    color: var(--vant-deep, #101711);
  }

  .vant-badge--lancamento {
    background: rgba(16, 23, 17, 0.32);
    border: 1px solid rgba(232, 208, 138, 0.60);
    color: var(--vant-gold-light, #e8d08a);
  }

  .vant-badge--limitado {
    background: rgba(16, 23, 17, 0.55);
    border: 1px solid rgba(232, 208, 138, 0.32);
    color: var(--vant-champagne, #d8c89f);
  }

  /* ── SVG ICON ───────────────────────────────────────── */

  .vant-product-icon {
    width: 36%;
    max-width: 130px;
    height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.20;
    transform: scale(0.76);
    transition: opacity 0.35s ease, transform 0.35s ease;
    pointer-events: none;
  }

  .vant-product-icon svg {
    width: 100%;
    height: 100%;
  }

  .vant-product-icon svg [stroke] {
    stroke: var(--vant-gold-light, #e8d08a);
  }

  .vant-product-card.is-visible:hover .vant-product-icon {
    opacity: 0.32;
    transform: scale(0.82);
  }

  /* ── WISHLIST BUTTON ────────────────────────────────── */

  .vant-wishlist-btn {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 3;
    width: 36px;
    height: 36px;
    background: rgba(16, 23, 17, 0.55);
    border: 1px solid rgba(232, 208, 138, 0.24);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transform: translateY(-4px) scale(0.88);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      background 0.3s ease,
      border-color 0.3s ease;
    color: var(--vant-champagne, #d8c89f);
  }

  .vant-wishlist-btn svg {
    width: 13px;
    height: 13px;
    transition: fill 0.25s ease;
  }

  .vant-product-card.is-visible:hover .vant-wishlist-btn {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .vant-wishlist-btn:hover {
    background: rgba(232, 208, 138, 0.12);
    color: var(--vant-gold-light, #e8d08a);
  }

  .vant-wishlist-btn.is-active {
    background: rgba(201, 168, 76, 0.14);
    border-color: rgba(201, 168, 76, 0.45);
    color: var(--vant-gold, #c9a84c);
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .vant-wishlist-btn.is-active svg path {
    fill: var(--vant-gold, #c9a84c);
  }

  /* ── PRODUCT INFO ───────────────────────────────────── */

  .vant-product-info {
    padding: 18px 20px 20px;
  }

  .vant-product-category {
    display: block;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--vant-nude, #cbbca2);
    margin-bottom: 6px;
  }

  .vant-product-name {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 21px;
    color: var(--vant-cream, #fbf4e6);
    line-height: 1.12;
    margin: 0 0 8px 0;
    transition: color 0.3s ease;
  }

  .vant-product-card.is-visible:hover .vant-product-name {
    color: #fff;
  }

  .vant-product-card h3 {
    font-size: 21px;
    line-height: 1.12;
  }

  .vant-product-price {
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    font-size: 15px;
    color: var(--vant-gold-light, #e8d08a);
    margin: 0;
    letter-spacing: 0.3px;
  }

  /* Cart badge spring on update */
  .vant-cart-badge {
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* ── RESPONSIVE ─────────────────────────────────────── */

  @media screen and (max-width: 1280px) {
    .vant-product-card {
      flex: 0 0 calc((100% - 56px) / 3);
    }
  }

  @media screen and (max-width: 990px) {
    .vant-products {
      padding: 72px 3vw 80px;
    }

    .vant-product-card {
      flex: 0 0 calc((100% - 28px) / 2);
    }

    .vant-products__header { margin-bottom: 40px; }
    .vant-products__filters { margin-bottom: 36px; }
  }

  @media screen and (max-width: 768px) {
    .vant-products {
      padding: 64px 22px;
    }

    .vant-product-card {
      flex: 0 0 82%;
      max-width: none;
      border-radius: 24px;
    }

    .vant-product-image {
      min-height: 230px;
      aspect-ratio: 1 / 0.9;
    }

    .vant-product-info {
      padding: 16px 18px 18px;
    }

    .vant-product-card h3,
    .vant-product-name {
      font-size: 20px;
    }

    .vant-carousel-arrow {
      display: none;
    }

    .vant-products__drag-hint {
      display: none;
    }
  }

  @media screen and (max-width: 480px) {
    .vant-products {
      padding: 64px 22px 72px;
    }

    .vant-product-card {
      flex: 0 0 88%;
    }

    .vant-products__title {
      font-size: 1.75rem;
    }

    .vant-filter-btn {
      font-size: 0.58rem;
      padding: 0.45rem 0.85rem 0.75rem;
      letter-spacing: 1.5px;
    }

    /* Always show wishlist on mobile (no hover) */
    .vant-wishlist-btn {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

<section class="vant-products" aria-labelledby="vant-products-title">
  <div class="vant-products__inner">

    {%- comment -%} Section header {%- endcomment -%}
    <header class="vant-products__header">
      <p class="vant-products__label">{{ section.settings.label }}</p>
      <h2 class="vant-products__title" id="vant-products-title">{{ section.settings.title }}</h2>
    </header>

    {%- comment -%} Filter tabs {%- endcomment -%}
    <div class="vant-products__filters" role="group" aria-label="Filtrar produtos">
      <button class="vant-filter-btn active" data-filter="todos" aria-pressed="true">
        {{ section.settings.tab_all }}
      </button>
      <button class="vant-filter-btn" data-filter="novidades" aria-pressed="false">
        {{ section.settings.tab_new }}
      </button>
      <button class="vant-filter-btn" data-filter="mais-vendidos" aria-pressed="false">
        {{ section.settings.tab_bestseller }}
      </button>
      <button class="vant-filter-btn" data-filter="lancamento" aria-pressed="false">
        {{ section.settings.tab_launch }}
      </button>
    </div>

    <p class="vant-products__drag-hint">Arraste para ver mais →</p>

    {%- comment -%} Product carousel {%- endcomment -%}
    <div class="vant-products-carousel-wrapper">
      <button class="vant-carousel-arrow vant-carousel-prev" type="button" aria-label="Produtos anteriores">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="vant-products-carousel" id="vant-carousel-{{ section.id }}" aria-label="Produtos VANT">

      {%- for block in section.blocks -%}

        <div
          class="vant-product-card"
          data-tab="{{ block.settings.tab }}"
          data-name="{{ block.settings.name | escape }}"
          data-price="{{ block.settings.price | escape }}"
          role="button"
          tabindex="0"
          aria-label="{{ block.settings.name }}, {{ block.settings.price }}"
          {{ block.shopify_attributes }}
        >

          {%- comment -%} Image area {%- endcomment -%}
          <div class="vant-product-image">

            {%- unless block.settings.badge == 'none' -%}
              <span class="vant-badge vant-badge--{{ block.settings.badge }}" aria-label="
                {%- case block.settings.badge -%}
                  {%- when 'novo' -%}Novo
                  {%- when 'lancamento' -%}Lançamento
                  {%- when 'limitado' -%}Limitado
                {%- endcase -%}
              ">
                {%- case block.settings.badge -%}
                  {%- when 'novo' -%}NOVO
                  {%- when 'lancamento' -%}LANÇAMENTO
                  {%- when 'limitado' -%}LIMITADO
                {%- endcase -%}
              </span>
            {%- endunless -%}

            {%- comment -%} Decorative SVG placeholder {%- endcomment -%}
            <div class="vant-product-icon" aria-hidden="true">
              {%- case block.settings.icon -%}

                {%- when 'ring' -%}
                <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="60" cy="60" r="44" stroke="#c9a84c" stroke-width="1.2"/>
                  <circle cx="60" cy="60" r="30" stroke="#c9a84c" stroke-width="0.5" stroke-dasharray="4 5"/>
                  <circle cx="60" cy="16" r="4.5" stroke="#c9a84c" stroke-width="0.8" fill="rgba(201,168,76,0.08)"/>
                </svg>

                {%- when 'pendant' -%}
                <svg viewBox="0 0 100 148" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <line x1="50" y1="5" x2="50" y2="30" stroke="#c9a84c" stroke-width="1" stroke-linecap="round"/>
                  <circle cx="50" cy="22" r="9" stroke="#c9a84c" stroke-width="1"/>
                  <path d="M50 42 C28 42, 14 64, 14 82 C14 110, 30 142, 50 142 C70 142, 86 110, 86 82 C86 64, 72 42, 50 42Z" stroke="#c9a84c" stroke-width="1"/>
                  <circle cx="50" cy="95" r="9" stroke="#c9a84c" stroke-width="0.5" stroke-dasharray="2.5 3"/>
                </svg>

                {%- when 'drop' -%}
                <svg viewBox="0 0 72 140" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <line x1="36" y1="5" x2="36" y2="28" stroke="#c9a84c" stroke-width="1" stroke-linecap="round"/>
                  <circle cx="36" cy="21" r="8" stroke="#c9a84c" stroke-width="1"/>
                  <path d="M36 40 C18 48, 10 68, 10 83 C10 109, 21 133, 36 133 C51 133, 62 109, 62 83 C62 68, 54 48, 36 40Z" stroke="#c9a84c" stroke-width="1"/>
                  <ellipse cx="36" cy="100" rx="10" ry="15" stroke="#c9a84c" stroke-width="0.5" stroke-dasharray="2 3"/>
                </svg>

                {%- when 'oval' -%}
                <svg viewBox="0 0 160 96" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <ellipse cx="80" cy="48" rx="70" ry="36" stroke="#c9a84c" stroke-width="1.2"/>
                  <ellipse cx="80" cy="48" rx="50" ry="22" stroke="#c9a84c" stroke-width="0.5" stroke-dasharray="4 5"/>
                  <circle cx="10"  cy="48" r="4.5" fill="#c9a84c" opacity="0.45"/>
                  <circle cx="150" cy="48" r="4.5" fill="#c9a84c" opacity="0.45"/>
                </svg>

                {%- when 'cluster' -%}
                <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="60" cy="60" r="18" stroke="#c9a84c" stroke-width="1.2"/>
                  <circle cx="26" cy="36" r="11" stroke="#c9a84c" stroke-width="0.9"/>
                  <circle cx="94" cy="36" r="11" stroke="#c9a84c" stroke-width="0.9"/>
                  <circle cx="26" cy="84" r="11" stroke="#c9a84c" stroke-width="0.9"/>
                  <circle cx="94" cy="84" r="11" stroke="#c9a84c" stroke-width="0.9"/>
                  <line x1="37" y1="43" x2="47" y2="51" stroke="#c9a84c" stroke-width="0.5"/>
                  <line x1="83" y1="43" x2="73" y2="51" stroke="#c9a84c" stroke-width="0.5"/>
                  <line x1="37" y1="77" x2="47" y2="69" stroke="#c9a84c" stroke-width="0.5"/>
                  <line x1="83" y1="77" x2="73" y2="69" stroke="#c9a84c" stroke-width="0.5"/>
                </svg>

                {%- else -%}
                <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="60" cy="60" r="44" stroke="#c9a84c" stroke-width="1"/>
                </svg>

              {%- endcase -%}
            </div>

            {%- comment -%} Wishlist button {%- endcomment -%}
            <button class="vant-wishlist-btn" aria-label="Adicionar aos favoritos" type="button">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </button>

          </div>

          {%- comment -%} Product info {%- endcomment -%}
          <div class="vant-product-info">
            <span class="vant-product-category">{{ block.settings.category }}</span>
            <h3 class="vant-product-name">{{ block.settings.name }}</h3>
            <p class="vant-product-price">{{ block.settings.price }}</p>
          </div>

        </div>

      {%- endfor -%}

      </div>

      <button class="vant-carousel-arrow vant-carousel-next" type="button" aria-label="Próximos produtos">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
(function () {
  'use strict';

  function initVantProductsCarousel(root) {
    var scope = root && root.querySelector ? root : document;
    var sections = [];

    if (scope.classList && scope.classList.contains('vant-products-section')) {
      sections.push(scope);
    }

    scope.querySelectorAll('.vant-products-section').forEach(function (sectionEl) {
      sections.push(sectionEl);
    });

    sections.forEach(initSection);
  }

  function initSection(sectionEl) {
    if (!sectionEl || sectionEl.dataset.vantCarouselReady === 'true') return;

    var carousel = sectionEl.querySelector('.vant-products-carousel');
    var filterBtns = sectionEl.querySelectorAll('.vant-filter-btn');
    var prevBtn = sectionEl.querySelector('.vant-carousel-prev');
    var nextBtn = sectionEl.querySelector('.vant-carousel-next');
    var cards = sectionEl.querySelectorAll('.vant-product-card');

    if (!carousel || !cards.length) return;

    sectionEl.dataset.vantCarouselReady = 'true';

    cards.forEach(function (card, index) {
      var delay = (index % 3) * 80;
      card.dataset.revealDelay = String(delay);
      card.style.opacity = '0';
      card.style.transform = 'translateY(18px)';
      setTimeout(function () {
        card.classList.add('is-visible');
        card.style.opacity = '';
        card.style.transform = '';
      }, 70 + delay);
    });

    function visibleCards() {
      return Array.prototype.filter.call(cards, function (card) {
        return !card.classList.contains('is-hidden');
      });
    }

    function cardStep() {
      var card = visibleCards()[0] || cards[0];
      if (!card) return 320;
      var gap = parseFloat(window.getComputedStyle(carousel).columnGap || window.getComputedStyle(carousel).gap) || 28;
      return card.getBoundingClientRect().width + gap;
    }

    function scrollCarousel(direction) {
      carousel.scrollBy({
        left: cardStep() * direction,
        behavior: 'smooth'
      });
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        scrollCarousel(-1);
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        scrollCarousel(1);
      });
    }

    function filterProducts(filter) {
      cards.forEach(function (card) {
        var matches = filter === 'todos' || card.dataset.tab === filter;
        card.classList.toggle('is-hidden', !matches);
        if (matches) {
          card.classList.add('is-visible');
        }
      });

      carousel.scrollTo({
        left: 0,
        behavior: 'smooth'
      });
    }

    filterBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        filterBtns.forEach(function (filterBtn) {
          filterBtn.classList.remove('active');
          filterBtn.setAttribute('aria-pressed', 'false');
        });

        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        filterProducts(btn.dataset.filter || 'todos');
      });
    });

    var isDown = false;
    var startX = 0;
    var startScrollLeft = 0;
    var moved = false;

    carousel.addEventListener('mousedown', function (event) {
      if (event.button !== 0) return;
      isDown = true;
      moved = false;
      startX = event.pageX;
      startScrollLeft = carousel.scrollLeft;
      carousel.classList.add('is-dragging');
    });

    carousel.addEventListener('mousemove', function (event) {
      if (!isDown) return;
      var delta = event.pageX - startX;
      if (Math.abs(delta) > 4) {
        moved = true;
      }
      carousel.scrollLeft = startScrollLeft - delta;
      event.preventDefault();
    });

    function endDrag() {
      isDown = false;
      carousel.classList.remove('is-dragging');
    }

    carousel.addEventListener('mouseup', endDrag);
    carousel.addEventListener('mouseleave', endDrag);

    carousel.addEventListener('click', function (event) {
      if (!moved) return;
      event.preventDefault();
      event.stopPropagation();
      moved = false;
    }, true);

    cards.forEach(function (card) {
      card.addEventListener('keydown', function (event) {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          triggerCard(card);
        }
      });

      card.addEventListener('click', function (event) {
        if (event.target.closest('.vant-wishlist-btn')) return;
        triggerCard(card);
      });
    });

    function triggerCard(card) {
      var name = card.dataset.name || '';
      var price = card.dataset.price || '';
      if (typeof window.openCheckout === 'function') {
        window.openCheckout(name, price);
      }
    }

    sectionEl.querySelectorAll('.vant-wishlist-btn').forEach(function (btn) {
      btn.addEventListener('click', function (event) {
        event.stopPropagation();
        var isNowActive = !btn.classList.contains('is-active');
        btn.classList.toggle('is-active', isNowActive);
        btn.setAttribute(
          'aria-label',
          isNowActive ? 'Remover dos favoritos' : 'Adicionar aos favoritos'
        );
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {
      initVantProductsCarousel(document);
    });
  } else {
    initVantProductsCarousel(document);
  }

  document.addEventListener('shopify:section:load', function (event) {
    initVantProductsCarousel(event.target);
  });
})();

if (!window.openCheckout) {
  window.openCheckout = function (nomeProduto, preco) {
    console.log('[VANT] Produto selecionado:', nomeProduto, preco);

    var badge = document.querySelector('.vant-cart-badge');
    if (badge) {
      var current = parseInt(badge.textContent, 10) || 0;
      badge.textContent = current + 1;
      badge.style.transform = 'scale(1.5)';
      setTimeout(function () { badge.style.transform = ''; }, 260);
    }
  };
}
</script>

