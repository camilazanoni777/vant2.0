    background: rgba(10, 17, 13, 0.28);
    color: var(--vant-text-muted, #8fa88a);
    border-radius: 12px;
    cursor: pointer;
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.4px;
    transition: border-color 0.25s, color 0.25s, background 0.25s;
    user-select: none;
  }

  .vant-co-pay-tab .pi {
    font-size: 1.25rem;
    line-height: 1;
  }

  .vant-co-pay-tab:hover {
    border-color: rgba(201, 168, 76, 0.4);
    color: var(--vant-cream, #f0e8d5);
  }

  .vant-co-pay-tab.active {
    border-color: var(--vant-gold, #c9a84c);
    color: var(--vant-gold, #c9a84c);
    background: rgba(201, 168, 76, 0.08);
  }

  /* ── PAYMENT PANELS ──────────────────────────────────── */

  .vant-co-panel {
    display: none;
  }

  .vant-co-panel.on {
    display: block;
  }

  /* Pix box */
  .vant-co-pix-box {
    border: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
    border-radius: 12px;
    background: rgba(10, 17, 13, 0.5);
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .vant-co-pix-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(201, 168, 76, 0.1);
    border: 0.5px solid rgba(201, 168, 76, 0.35);
    color: var(--vant-gold, #c9a84c);
    font-family: 'Jost', sans-serif;
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 20px;
    width: fit-content;
  }

  .vant-co-pix-code {
    font-family: 'Courier New', monospace;
    font-size: 0.64rem;
    color: var(--vant-text-muted, #8fa88a);
    word-break: break-all;
    line-height: 1.65;
    background: rgba(10, 17, 13, 0.55);
    border: 0.5px solid rgba(201, 168, 76, 0.1);
    border-radius: 8px;
    padding: 12px 14px;
  }

  .vant-co-pix-copy {
    background: transparent;
    border: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
    color: var(--vant-gold, #c9a84c);
    padding: 10px 16px;
    border-radius: 8px;
    font-family: 'Jost', sans-serif;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.25s, background 0.25s;
    width: fit-content;
  }

  .vant-co-pix-copy:hover {
    border-color: var(--vant-gold, #c9a84c);
    background: rgba(201, 168, 76, 0.06);
  }

  .vant-co-pix-note {
    font-family: 'Jost', sans-serif;
    font-size: 0.75rem;
    font-weight: 300;
    color: var(--vant-text-muted, #8fa88a);
    line-height: 1.7;
    margin: 0;
  }

  /* Boleto box */
  .vant-co-boleto-box {
    border: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
    border-radius: 12px;
    background: rgba(10, 17, 13, 0.5);
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .vant-co-boleto-box p {
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem;
    font-weight: 300;
    color: var(--vant-text-muted, #8fa88a);
    line-height: 1.65;
    margin: 0;
  }

  /* ── SUBMIT ──────────────────────────────────────────── */

  .vant-co-submit {
    width: 100%;
    background: var(--vant-gold, #c9a84c);
    color: var(--vant-deep, #0a110d);
    border: none;
    padding: 18px 22px;
    border-radius: 12px;
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    cursor: pointer;
    margin-top: 8px;
    transition: background 0.3s;
  }

  .vant-co-submit:hover {
    background: var(--vant-gold-light, #e8d08a);
  }

  .vant-co-security {
    text-align: center;
    font-family: 'Jost', sans-serif;
    font-size: 0.63rem;
    color: var(--vant-text-muted, #8fa88a);
    opacity: 0.55;
    letter-spacing: 0.3px;
    margin-top: 6px;
  }

  /* ── RIGHT COLUMN ────────────────────────────────────── */

  .vant-co-summary-col {
    background: var(--vant-moss, #1a3322);
    padding: 48px 32px;
    border-left: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .vant-co-summary-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.45rem;
    color: var(--vant-cream, #f0e8d5);
    margin: 0;
  }

  /* Product row */
  .vant-co-product {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .vant-co-product-thumb {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    border-radius: 10px;
    background: rgba(10, 17, 13, 0.5);
    border: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vant-co-product-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .vant-co-product-name {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 0.86rem;
    color: var(--vant-cream, #f0e8d5);
    line-height: 1.4;
  }

  .vant-co-product-variant {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    font-weight: 300;
    color: var(--vant-text-muted, #8fa88a);
  }

  .vant-co-product-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: var(--vant-gold, #c9a84c);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Divider */
  .vant-co-divider {
    border: none;
    border-top: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
    margin: 0;
  }

  /* Shipping calc */
  .vant-co-ship-label {
    font-family: 'Jost', sans-serif;
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--vant-text-muted, #8fa88a);
    margin-bottom: 10px;
  }

  .vant-co-ship-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
  }

  .vant-co-ship-result {
    margin-top: 10px;
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem;
    color: var(--vant-text-muted, #8fa88a);
    min-height: 20px;
  }

  .vant-co-ship-free {
    color: var(--vant-gold, #c9a84c);
    font-weight: 500;
  }

  /* Totals */
  .vant-co-totals {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .vant-co-total-line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'Jost', sans-serif;
    font-size: 0.8rem;
    font-weight: 300;
    color: var(--vant-text-muted, #8fa88a);
  }

  .vant-co-total-line.pix-discount {
    color: var(--vant-gold-light, #e8d08a);
  }

  .vant-co-total-line.hidden {
    display: none;
  }

  .vant-co-total-final {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
    padding-top: 16px;
    margin-top: 4px;
  }

  .vant-co-total-label {
    font-family: 'Jost', sans-serif;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--vant-cream, #f0e8d5);
  }

  .vant-co-total-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-weight: 400;
    color: var(--vant-gold, #c9a84c);
    line-height: 1;
  }

  /* ── CONFIRMATION SCREEN ─────────────────────────────── */

  .vant-co-confirm {
    display: none;
    padding: 80px 48px;
    text-align: center;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    flex: 1;
  }

  .vant-co-confirm.on {
    display: flex;
  }

  .vant-co-confirm-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(201, 168, 76, 0.1);
    border: 0.5px solid rgba(201, 168, 76, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
  }

  .vant-co-confirm-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.7rem, 3.5vw, 2.5rem);
    font-weight: 400;
    color: var(--vant-cream, #f0e8d5);
