                <input class="vant-co-input" type="tel" id="vco-phone"
                  placeholder="(00) 00000-0000" maxlength="15" inputmode="numeric">
              </div>
            </div>

          </div>
        </div>

        <!-- STEP 2 · ENDEREÇO -->
        <div>
          <p class="vant-co-step">Endere&#231;o de Entrega</p>
