<style>
  /* ── VANT CHECKOUT MODAL ──────────────────────────────── */

  .vant-checkout-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 17, 13, 0.96);
    z-index: 9000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 16px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .vant-checkout-overlay.is-active {
    display: flex;
  }

  /* ── MODAL SHELL ─────────────────────────────────────── */

  .vant-checkout-modal {
    position: relative;
    width: min(1120px, calc(100vw - 32px));
    max-height: calc(100vh - 32px);
    background: var(--vant-forest, #0f1f15);
    border: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
    border-radius: 28px;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.75), 0 8px 24px rgba(0, 0, 0, 0.5);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── CONTENT WRAP (2-col grid) ───────────────────────── */

  .vant-co-content {
    display: grid;
    grid-template-columns: 1.35fr 0.9fr;
    flex: 1;
    overflow-y: auto;
  }

  .vant-co-content::-webkit-scrollbar { width: 3px; }
  .vant-co-content::-webkit-scrollbar-track { background: transparent; }
  .vant-co-content::-webkit-scrollbar-thumb {
    background: rgba(201, 168, 76, 0.18);
    border-radius: 2px;
  }

  /* ── CLOSE BUTTON ────────────────────────────────────── */

  .vant-co-close {
    position: absolute;
    top: 18px;
    right: 18px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(10, 17, 13, 0.6);
    border: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
    color: var(--vant-gold, #c9a84c);
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.25s, background 0.25s;
    z-index: 20;
    flex-shrink: 0;
  }

  .vant-co-close:hover {
    border-color: var(--vant-gold, #c9a84c);
    background: rgba(201, 168, 76, 0.08);
  }

  /* ── LEFT COLUMN ─────────────────────────────────────── */

  .vant-co-form-col {
    padding: 48px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .vant-co-main-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: clamp(1.75rem, 2.4vw, 2.4rem);
    color: var(--vant-cream, #f0e8d5);
    margin: 0;
    padding-right: 44px;
  }

  /* ── STEP LABEL ──────────────────────────────────────── */

  .vant-co-step {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 0.57rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--vant-gold, #c9a84c);
    margin-bottom: 18px;
  }

  .vant-co-step::after {
    content: '';
    flex: 1;
    height: 0.5px;
    background: linear-gradient(to right, rgba(201, 168, 76, 0.3), transparent);
  }

  /* ── FORM FIELDS ─────────────────────────────────────── */

  .vant-co-fields {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .vant-co-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .vant-co-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .vant-co-field label {
    font-family: 'Jost', sans-serif;
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--vant-text-muted, #8fa88a);
  }

  .vant-co-input,
  .vant-co-select {
    background: rgba(10, 17, 13, 0.4);
    border: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
    color: var(--vant-text, #e8dfc8);
    padding: 13px 16px;
    border-radius: 10px;
    font-family: 'Jost', sans-serif;
    font-size: 0.83rem;
    font-weight: 300;
