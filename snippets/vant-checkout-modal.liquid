    max-width: 460px;
    margin: 0;
  }

  .vant-co-confirm-num {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--vant-gold, #c9a84c);
    background: rgba(201, 168, 76, 0.08);
    border: 0.5px solid rgba(201, 168, 76, 0.25);
    border-radius: 8px;
    padding: 10px 22px;
  }

  .vant-co-continue {
    background: transparent;
    border: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
    color: var(--vant-gold, #c9a84c);
    padding: 14px 30px;
    border-radius: 10px;
    font-family: 'Jost', sans-serif;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.25s, background 0.25s;
  }

  .vant-co-continue:hover {
    border-color: var(--vant-gold, #c9a84c);
    background: rgba(201, 168, 76, 0.06);
  }

  /* ── RESPONSIVE ──────────────────────────────────────── */

  @media screen and (max-width: 989px) {
    .vant-co-content {
      grid-template-columns: 1fr 0.75fr;
    }
    .vant-co-form-col {
      padding: 36px 28px;
    }
    .vant-co-summary-col {
      padding: 36px 22px;
    }
  }

  @media screen and (max-width: 768px) {
    .vant-co-content {
      grid-template-columns: 1fr;
    }
    .vant-co-summary-col {
      order: -1;
      border-left: none;
      border-bottom: 0.5px solid var(--vant-border, rgba(201, 168, 76, 0.2));
      padding: 28px 24px;
      gap: 18px;
    }
    .vant-co-form-col {
      padding: 28px 24px;
      gap: 24px;
    }
    .vant-co-confirm {
      padding: 60px 28px;
    }
  }

  @media screen and (max-width: 480px) {
    .vant-checkout-overlay {
      padding: 8px;
    }
    .vant-checkout-modal {
      width: calc(100vw - 16px);
      border-radius: 20px;
    }
    .vant-co-row {
      grid-template-columns: 1fr;
    }
    .vant-co-pay-tab {
      padding: 12px 6px;
      font-size: 0.64rem;
    }
    .vant-co-pay-tab .pi {
      font-size: 1.1rem;
    }
  }
</style>

<!-- ── VANT CHECKOUT MODAL HTML ───────────────────────── -->

<div
  class="vant-checkout-overlay"
  id="vant-co-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="vant-co-title"
>
  <div class="vant-checkout-modal" id="vant-co-modal">

    <!-- Close -->
    <button class="vant-co-close" id="vant-co-close" aria-label="Fechar">&#x2715;</button>

    <!-- ── 2-col content ─────────────────────────────────── -->
    <div class="vant-co-content" id="vant-co-content">

      <!-- LEFT: form -->
      <div class="vant-co-form-col">

        <h2 class="vant-co-main-title" id="vant-co-title">Finalizar Pedido</h2>

        <!-- STEP 1 · DADOS PESSOAIS -->
        <div>
          <p class="vant-co-step">Dados Pessoais</p>
          <div class="vant-co-fields">

            <div class="vant-co-field">
              <label for="vco-name">Nome completo</label>
              <input class="vant-co-input" type="text" id="vco-name"
                placeholder="Seu nome completo" autocomplete="name">
            </div>

            <div class="vant-co-field">
              <label for="vco-email">E-mail</label>
              <input class="vant-co-input" type="email" id="vco-email"
                placeholder="seu@email.com" autocomplete="email">
            </div>

            <div class="vant-co-row">
              <div class="vant-co-field">
